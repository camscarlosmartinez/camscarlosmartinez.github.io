---
const dimensions=['Problema público y finalidad','Competencia y ruta jurídica','Alternativas comparadas','Impacto fiscal y sostenibilidad','Talento y relaciones laborales','Datos e interoperabilidad','Gestión documental y archivo','Capacidad territorial','Contratación y capacidades internas','Participación y observaciones','Riesgos y salvaguardas','Cronograma y responsables','Indicadores y línea base','Evaluación y decisión posterior'];
---
<section class="tool checklist" data-expediente><h2>Constructor local del expediente</h2><p>Marque las dimensiones revisadas. El avance se guarda solamente en este navegador.</p><p><strong data-progress>0 de 14 revisadas</strong></p>{dimensions.map((d,i)=><label><input type="checkbox" value={i} /> {d}</label>)}<button type="button" data-clear>Limpiar avance</button></section>
<script>
 // @ts-nocheck
 const root=document.querySelector<HTMLElement>('[data-expediente]');if(root){const boxes=[...root.querySelectorAll<HTMLInputElement>('input')];const key='cams-expediente-v1';try{const saved=JSON.parse(localStorage.getItem(key)||'[]');boxes.forEach((b,i)=>b.checked=saved.includes(i))}catch{}const update=()=>{const values=boxes.map((b,i)=>b.checked?i:null).filter(x=>x!==null);root.querySelector('[data-progress]').textContent=`${values.length} de ${boxes.length} revisadas`;localStorage.setItem(key,JSON.stringify(values))};boxes.forEach(b=>b.addEventListener('change',update));root.querySelector('[data-clear]')?.addEventListener('click',()=>{boxes.forEach(b=>b.checked=false);update()});update()}
</script>
