<section class="tool" data-problem-tree><h2>Árbol del problema</h2><p>Filtre las 18 fichas por su lugar en el diagnóstico y seleccione una para revisar su pregunta.</p><div class="tool-controls"><button type="button" data-level="all" aria-pressed="true">Todo</button><button type="button" data-level="causa" aria-pressed="false">9 causas</button><button type="button" data-level="problema" aria-pressed="false">Problema central</button><button type="button" data-level="efecto" aria-pressed="false">8 efectos</button></div><div class="cards" data-tree-list aria-live="polite"><p>Cargando diagnóstico…</p></div><div class="tool-output" data-tree-output><strong>Seleccione una ficha.</strong></div></section>
<script>
 // @ts-nocheck
 const root=document.querySelector<HTMLElement>('[data-problem-tree]'); if(root){fetch('/assets/data/problem-tree.json').then(r=>r.json()).then(data=>{const list=root.querySelector<HTMLElement>('[data-tree-list]');const out=root.querySelector<HTMLElement>('[data-tree-output]');let level='all';const draw=()=>{const nodes=data.nodes.filter(n=>level==='all'||n.level===level);list.innerHTML=nodes.map(n=>`<button class="card" type="button" data-id="${n.id}"><span class="status">${n.type}</span><strong>${n.title}</strong><small>${n.dimension}</small></button>`).join('');list.querySelectorAll('button').forEach(b=>b.addEventListener('click',()=>{const n=data.nodes.find(x=>x.id===b.dataset.id);out.innerHTML=`<h3>${n.title}</h3><p>${n.explanation}</p><p><strong>Indicio:</strong> ${n.evidence}</p><p><strong>Pregunta:</strong> ${n.question}</p><p><strong>Herramienta:</strong> ${n.tool}. ${n.response}</p>`}))};root.querySelectorAll('[data-level]').forEach(b=>b.addEventListener('click',()=>{level=b.dataset.level;root.querySelectorAll('[data-level]').forEach(x=>x.setAttribute('aria-pressed',String(x===b)));draw()}));draw()}).catch(()=>{root.querySelector('[data-tree-list]').textContent='No fue posible cargar los datos del diagnóstico.'})}
</script>
