<section class="tool" data-inst-map><h2>Mapa institucional propuesto</h2><p>Explore funciones y conexiones. Ninguna de estas instancias se presenta como adoptada.</p><div class="tool-controls" data-inst-buttons></div><div class="tool-output" data-inst-output aria-live="polite"></div></section>
<script>
 // @ts-nocheck
 const root=document.querySelector<HTMLElement>('[data-inst-map]');if(root)fetch('/assets/data/proposal-architecture.json').then(r=>r.json()).then(data=>{const btns=root.querySelector<HTMLElement>('[data-inst-buttons]');const out=root.querySelector<HTMLElement>('[data-inst-output]');btns.innerHTML=data.institutions.map((n,i)=>`<button type="button" data-id="${n.id}" aria-pressed="${i===0}">${n.title}</button>`).join('');const show=id=>{const n=data.institutions.find(x=>x.id===id);out.innerHTML=`<h3>${n.title}</h3><p>${n.function}</p><dl class="meta"><div><dt>Recibe</dt><dd>${n.input}</dd></div><div><dt>Entrega</dt><dd>${n.output}</dd></div><div><dt>Conecta</dt><dd>${n.connectionLabel}</dd></div></dl>`};btns.querySelectorAll('button').forEach(b=>b.addEventListener('click',()=>{btns.querySelectorAll('button').forEach(x=>x.setAttribute('aria-pressed',String(x===b)));show(b.dataset.id)}));show(data.institutions[0].id)})
</script>
