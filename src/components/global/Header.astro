---
import BrandLogo from '../brand/BrandLogo.astro';
const { currentPath = '/' } = Astro.props;
const primary = [
  ['/', 'Inicio'], ['/cams/', 'CAMS'], ['/estado-que-cumple/', 'Estado que Cumple'],
  ['/propuestas/', 'Propuestas'], ['/conocimiento/', 'Conocimiento'], ['/participar/', 'Participar']
];
const knowledge = [['/investigaciones/','Investigaciones'],['/documentos/','Documentos'],['/bitacora/','Bitácora'],['/observatorio/','Observatorio'],['/archivo/','Archivo']];
const active = (href:string) => href === '/' ? currentPath === '/' : currentPath.startsWith(href);
const knowledgeActive = currentPath.startsWith('/conocimiento') || knowledge.some(([href]) => active(href));
---
<header class="site-header">
  <div class="container header-inner">
    <BrandLogo compact />
    <div class="header-actions">
      <button class="search-trigger" type="button" data-search-open aria-controls="command-palette" aria-expanded="false">Buscar <kbd>Ctrl K</kbd></button>
      <button class="menu-toggle" type="button" data-menu-toggle aria-controls="primary-nav" aria-expanded="false">Menú</button>
    </div>
    <nav id="primary-nav" class="site-nav" aria-label="Navegación principal">
      <ul>{primary.map(([href,label]) => <li class:list={{knowledge: label==='Conocimiento'}}>
        <a href={href} aria-current={(label==='Conocimiento' ? knowledgeActive : active(href)) ? 'page' : undefined}>{label}</a>
        {label === 'Conocimiento' && <><button type="button" data-submenu aria-expanded="false" aria-controls="knowledge-menu" aria-label="Abrir secciones de Conocimiento">▾</button><ul id="knowledge-menu" class="submenu" hidden>{knowledge.map(([h,l]) => <li><a href={h} aria-current={active(h)?'page':undefined}>{l}</a></li>)}</ul></>}
      </li>)}</ul>
    </nav>
  </div>
</header>
<script>
  const menu = document.querySelector<HTMLElement>('[data-menu-toggle]'); const nav = document.querySelector<HTMLElement>('#primary-nav');
  const sub = document.querySelector<HTMLElement>('[data-submenu]'); const panel = document.querySelector<HTMLElement>('#knowledge-menu');
  menu?.addEventListener('click',()=>{const open=menu.getAttribute('aria-expanded')!=='true'; menu.setAttribute('aria-expanded',String(open)); nav?.classList.toggle('open',open)});
  sub?.addEventListener('click',()=>{const open=sub.getAttribute('aria-expanded')!=='true';sub.setAttribute('aria-expanded',String(open));if(panel)panel.hidden=!open});
  document.addEventListener('keydown',e=>{if(e.key==='Escape'){menu?.setAttribute('aria-expanded','false');nav?.classList.remove('open');sub?.setAttribute('aria-expanded','false');if(panel)panel.hidden=true;}});
</script>
