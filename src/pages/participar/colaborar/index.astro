---
import BaseLayout from '../../../layouts/BaseLayout.astro';import PageHero from '../../../components/global/PageHero.astro';
const issue='https://github.com/camscarlosmartinez/camscarlosmartinez.github.io/issues/new?template=propuesta-de-colaboracion.yml&title=%5BColaboraci%C3%B3n%5D%20';
---
<BaseLayout title="Colaborar" description="Alcance y plantilla pública para proponer colaboraciones concretas con CAMS." currentPath="/participar/colaborar/"><PageHero eyebrow="Participar" title="Proponer colaboración" lead="Aportes con objetivo, alcance, producto y disponibilidad claros; sin simular un programa de voluntariado."/><div class="container page"><section class="section"><h2>Ámbitos pertinentes</h2><div class="cards"><article class="card"><h3>Revisión documental</h3><p>Fuentes, metadatos, citación, lenguaje claro y control de versiones.</p></article><article class="card"><h3>Datos y accesibilidad</h3><p>Metodología, diccionarios, visualización, teclado y alternativas textuales.</p></article><article class="card"><h3>Contraste institucional</h3><p>Competencias, riesgos, viabilidad, territorio e implementación.</p></article></div><h2>Propuesta mínima</h2><p>Explique objetivo, pieza relacionada, aporte, producto esperado, tiempo disponible, condición pública del intercambio y posibles conflictos de interés.</p><a class="button primary" href={issue}>Crear propuesta pública</a></section></div></BaseLayout>
