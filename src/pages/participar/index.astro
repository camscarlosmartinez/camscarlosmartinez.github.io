---
import BaseLayout from '../../layouts/BaseLayout.astro';import PageHero from '../../components/global/PageHero.astro';
---
<BaseLayout title="Participar" description="Acciones reales para corregir, aportar fuentes, comentar, colaborar, seguir y compartir CAMS." currentPath="/participar/">
  <PageHero eyebrow="Participación pública" title="Participar en CAMS" lead="Observaciones concretas, fuentes verificables y colaboración mediante canales públicos y trazables."/>
  <div class="container page"><section class="section"><div class="cards"><article class="card"><h2>Corregir un error</h2><p>Identifique página, afirmación, corrección propuesta y soporte.</p><a href="/participar/correcciones/">Abrir guía</a></article><article class="card"><h2>Aportar una fuente</h2><p>Comparta referencia, alcance, relevancia y vínculo con una pieza.</p><a href="/participar/aportar-fuente/">Abrir guía</a></article><article class="card"><h2>Comentar o colaborar</h2><p>Proponga una revisión técnica, editorial o de accesibilidad con alcance definido.</p><a href="/participar/colaborar/">Revisar alcance</a></article></div></section>
  <section class="section"><h2>Seguir y compartir</h2><p>No existe formulario, lista de correo ni backend. Las actualizaciones se consultan en el repositorio y canales públicos confirmados.</p><ul class="channels"><li><a href="https://github.com/camscarlosmartinez" target="_blank" rel="noopener">GitHub <span>@camscarlosmartinez</span></a></li><li><a href="https://www.instagram.com/cams.carlosmartinez/" target="_blank" rel="noopener">Instagram <span>@cams.carlosmartinez</span></a></li><li><a href="https://co.linkedin.com/in/cams0802" target="_blank" rel="noopener">LinkedIn <span>Perfil profesional</span></a></li><li><a href="https://www.facebook.com/CAMS.CarlosMartinez/" target="_blank" rel="noopener">Facebook <span>CAMS Carlos Martínez</span></a></li></ul><button class="button primary" type="button" data-share>Compartir esta página</button><span data-share-feedback aria-live="polite"></span></section></div>
  <script>
    document.querySelector('[data-share]')?.addEventListener('click', async () => {
      const out = document.querySelector<HTMLElement>('[data-share-feedback]');
      try { if (navigator.share) await navigator.share({title:document.title,url:location.href}); else { await navigator.clipboard.writeText(location.href); if(out) out.textContent=' Enlace copiado.'; } }
      catch { if(out) out.textContent=' No se compartió el enlace.'; }
    });
  </script>
</BaseLayout>
