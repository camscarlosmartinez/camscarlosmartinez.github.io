---
import BaseLayout from '../layouts/BaseLayout.astro';import PageHero from '../components/global/PageHero.astro';import DocumentCard from '../components/global/DocumentCard.astro';
const desc='Plataforma personal de Carlos Arturo Martínez Sánchez para investigación pública, diseño institucional, propuestas, seguimiento y participación.';
---
<BaseLayout title="CAMS" description={desc} currentPath="/" jsonLd={{'@context':'https://schema.org','@type':'WebSite',name:'CAMS',url:'https://camscarlosmartinez.github.io',author:{'@type':'Person',name:'Carlos Arturo Martínez Sánchez'}}}>
<PageHero eyebrow="Carlos Arturo Martínez Sánchez · CAMS" title="Propuestas y conocimiento para que el Estado cumpla" lead="Investigación pública, diseño institucional, seguimiento y participación para convertir problemas verificables en alternativas discutibles, corregibles y trazables."><div class="actions"><a class="button primary" href="/estado-que-cumple/">Explorar Estado que Cumple</a><a class="button secondary" href="/cams/">Conocer CAMS</a></div></PageHero>
<div class="container page">
 <section class="section section-grid"><div class="prose"><p class="eyebrow">Proyecto insignia</p><h2>Estado que Cumple</h2><p class="lede">El problema no es solo la ausencia de normas: también es la brecha entre las formas institucionales creadas y la capacidad real para implementarlas.</p><p>La tesis propone revisar lo existente, estimar madurez, pilotear cuando haya incertidumbre y decidir mediante un expediente técnico y el instrumento competente.</p><ol class="process"><li>Problema</li><li>RAÍCES</li><li>SAVIA</li><li>SEMILLAS</li><li>Expediente</li><li>Implementación</li><li>Evaluación</li></ol><div class="actions"><a class="button primary" href="/estado-que-cumple/">Abrir micrositio</a><a class="button" href="/estado-que-cumple/documento/">Ver documento</a></div></div><aside class="callout"><span class="status">Propuesta pública</span><h3>No es una política oficial</h3><p>Es una propuesta ciudadana, técnica y programática abierta a crítica, adaptación y corrección.</p></aside></section>
 <section class="section"><p class="eyebrow">Trabajo reciente</p><h2>Una publicación disponible</h2><div class="cards"><DocumentCard title="Estado que Cumple 2026–2030" summary="Documento técnico-político de discusión pública, publicado el 6 de junio de 2026 según los metadatos del PDF." href="/documentos/estado-que-cumple-2026-2030/" /></div></section>
 <section class="section"><p class="eyebrow">Agenda de trabajo</p><h2>Cuatro campos conectados</h2><div class="cards"><article class="card"><h3>Capacidad estatal</h3><p>Funciones, recursos, talento, datos, archivo, control y resultados.</p></article><article class="card"><h3>Administración y territorio</h3><p>Competencias y condiciones diferenciadas de implementación.</p></article><article class="card"><h3>Participación y juventud</h3><p>Aportes públicos que dejen evidencia, respuesta y memoria.</p></article><article class="card"><h3>Infraestructura y políticas públicas</h3><p>Diseño, coordinación y ejecución desde la capacidad institucional.</p></article></div></section>
 <section class="section section-grid"><div><p class="eyebrow">Método CAMS</p><h2>Del problema a una versión pública</h2><ol class="process"><li>Investigar</li><li>Diagnosticar</li><li>Formular</li><li>Contrastar</li><li>Publicar</li><li>Corregir y versionar</li></ol><a href="/cams/metodo/">Conocer el método completo →</a></div><div><p class="eyebrow">Perfil</p><h2>Carlos Arturo Martínez Sánchez</h2><p>Estudiante de Administración Pública en la ESAP. CAMS es su identidad pública personal, método editorial y archivo independiente.</p><a href="/cams/trayectoria/">Consultar trayectoria verificable →</a></div></section>
 <section class="section"><p class="eyebrow">Participación real</p><h2>Corregir, documentar y colaborar</h2><div class="cards"><article class="card"><h3>Corregir un error</h3><a href="/participar/correcciones/">Abrir guía y canal</a></article><article class="card"><h3>Aportar una fuente</h3><a href="/participar/aportar-fuente/">Proponer referencia</a></article><article class="card"><h3>Comentar o colaborar</h3><a href="/participar/colaborar/">Revisar alcance</a></article></div></section>
</div></BaseLayout>
