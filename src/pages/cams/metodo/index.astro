import BaseLayout from '../../../layouts/BaseLayout.astro';import PageHero from '../../../components/global/PageHero.astro';import SectionNavigation from '../../../components/global/SectionNavigation.astro';import {camsNav} from '../../../data/navigation';
---
<BaseLayout title="Método CAMS" description="Método de investigación, formulación, contraste, publicación y corrección de CAMS." currentPath="/cams/metodo/"><PageHero eyebrow="CAMS · Método" title="Del problema a una versión pública" lead="Un flujo editorial para distinguir evidencia, análisis, propuesta y estado de publicación."/><div class="container page"><SectionNavigation items={camsNav} currentPath="/cams/metodo/"/><section class="section"><ol class="process"><li>Problema</li><li>Fuentes</li><li>Marco de análisis</li><li>Competencias</li><li>Alternativas</li><li>Propuesta</li><li>Revisión pública</li><li>Versión</li></ol></section><section class="section"><div class="cards"><article class="card"><h2>Investigar y diagnosticar</h2><p>Delimitar la pregunta; identificar fuentes, vacíos y restricciones; separar indicio de resultado.</p></article><article class="card"><h2>Formular y contrastar</h2><p>Revisar competencias, comparar alternativas, explicitar riesgos y abrir la propuesta a objeciones.</p></article><article class="card"><h2>Publicar y corregir</h2><p>Asignar estado, versión y fecha; conservar el archivo; responder errores mediante cambios trazables.</p></article></div></section></div></BaseLayout>
