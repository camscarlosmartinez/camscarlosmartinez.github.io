---
import '../styles/global.css';
import SkipLink from '../components/global/SkipLink.astro';
import Header from '../components/global/Header.astro';
import Footer from '../components/global/Footer.astro';
import SeoHead from '../components/global/SeoHead.astro';
import CommandPalette from '../components/global/CommandPalette.astro';
import Breadcrumbs from '../components/global/Breadcrumbs.astro';
import BrandSignature from '../components/brand/BrandSignature.astro';
import BrandPattern from '../components/brand/BrandPattern.astro';
interface Props { title: string; description: string; currentPath?: string; type?: string; jsonLd?: Record<string, unknown>; }
const { title, description, currentPath = Astro.url.pathname, type = 'website', jsonLd } = Astro.props;
const fullTitle = title === 'CAMS' ? 'CAMS — Carlos Arturo Martínez Sánchez' : `${title} · CAMS`;
const site = Astro.site ?? new URL('https://camscarlosmartinez.github.io');
const canonical = new URL(Astro.url.pathname, site).toString();
const brandedContext = currentPath.startsWith('/cams/') || ['/documentos/', '/archivo/'].includes(currentPath);
const patternedContext = currentPath.startsWith('/estado-que-cumple/') || ['/documentos/', '/archivo/', '/404.html'].includes(currentPath);
const signatureLabel = currentPath.startsWith('/cams/criterios-y-transparencia/') ? 'Responsabilidad editorial' : currentPath === '/documentos/' ? 'Biblioteca y autoría' : currentPath === '/archivo/' ? 'Custodia y memoria editorial' : 'Autor y responsable de CAMS';
---
<!doctype html>
<html lang="es-CO">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#071d33" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" href="/assets/favicon.svg" type="image/svg+xml" />
    <link rel="manifest" href="/site.webmanifest" />
    <SeoHead title={fullTitle} description={description} canonical={canonical} type={type} />
    {jsonLd && <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
  </head>
  <body>
    <div class="reading-progress" data-reading-progress aria-hidden="true"><span></span></div>
    <SkipLink />
    <Header currentPath={currentPath} />
    <main id="contenido" tabindex="-1">
      {patternedContext && <BrandPattern tone="light" />}
      {currentPath !== '/' && <div class="container" style="padding-top:1rem"><Breadcrumbs items={[{label:'Inicio',href:'/'},{label:title}]} /></div>}
      {brandedContext && <div class="container brand-context"><BrandSignature context={signatureLabel} /></div>}
      <slot />
    </main>
    <Footer />
    <CommandPalette />
    <script>
      const bar = document.querySelector<HTMLElement>('[data-reading-progress] span');
      const update = () => { const max = document.documentElement.scrollHeight - innerHeight; if (bar) bar.style.width = `${max > 0 ? scrollY / max * 100 : 0}%`; };
      addEventListener('scroll', update, { passive: true }); update();
    </script>
  </body>
</html>
