---
import '../styles/global.css';
import SkipLink from '../components/global/SkipLink.astro';
import Header from '../components/global/Header.astro';
import Footer from '../components/global/Footer.astro';
import SeoHead from '../components/global/SeoHead.astro';

interface Props {
  title?: string;
  description?: string;
  currentPath?: string;
  canonical?: string;
  image?: string;
  type?: string;
  robots?: string;
  locale?: string;
  author?: string;
}

const {
  title = 'CAMS',
  description = 'Plataforma pública de investigación, propuestas y participación de CAMS.',
  currentPath = '/',
  canonical,
  image = '/assets/og-cams-v3.png',
  type = 'website',
  robots = 'index, follow',
  locale = 'es_CO',
  author = 'Carlos Arturo Martínez Sánchez',
} = Astro.props as Props;

const siteTitle = title === 'CAMS' ? 'CAMS — Carlos Arturo Martínez Sánchez' : `${title} · CAMS`;
const siteUrl = Astro.site ?? new URL('https://camscarlosmartinez.github.io');
const canonicalUrl = new URL(canonical ?? Astro.url.pathname, siteUrl).toString();
const socialImageUrl = new URL(image, siteUrl).toString();
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#071d33" />
    <link rel="icon" href="/assets/favicon.svg" type="image/svg+xml" />
    <link rel="manifest" href="/site.webmanifest" />
    <SeoHead
      title={siteTitle}
      description={description}
      canonical={canonicalUrl}
      image={socialImageUrl}
      type={type}
      robots={robots}
      locale={locale}
      author={author}
    />
  </head>
  <body>
    <SkipLink />
    <div class="site-shell">
      <Header currentPath={currentPath} />
      <main id="main-content" tabindex="-1">
        <slot />
      </main>
      <Footer />
    </div>
  </body>
</html>
